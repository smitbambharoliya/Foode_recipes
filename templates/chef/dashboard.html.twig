{% extends 'chef/layout.html.twig' %}

{% block chef_styles %}
<link rel="stylesheet" href="{{ asset('css/chef_dashboard.css') }}">
{% endblock %}

{% block chef_content %}
    <h2 class="section-title" style="margin-bottom: 15px;">Explore Categories</h2>
    <div class="categories">
        <div class="category-pill active">
            <i class="fas fa-fire" style="color: #ff5722; font-size: 1.2rem;"></i> All
        </div>
        {% for region in regions %}
            <div class="category-pill">
                <i class="fas fa-utensils" style="color: #ffc107; font-size: 1.2rem;"></i> {{ region.name }}
            </div>
        {% endfor %}
    </div>

    <div class="food-header">
        <h2 class="section-title" style="margin: 0;">Popular & Recent</h2>
        <a href="{{ path('app_chef_recipe') }}" style="color: #ff5722; text-decoration: none; font-weight: 600; font-size: 0.95rem;">View All</a>
    </div>

    {% if recentRecipes|length > 0 %}
        <div class="food-grid">
            {% for recipe in recentRecipes %}
                <div class="food-card">
                    <div class="badge"><i class="fas fa-fire"></i></div>
                    {% if recipe.image %}
                        <img src="{{ asset('uploads/recipes/' ~ recipe.image) }}" alt="{{ recipe.title }}">
                    {% else %}
                        <div class="no-image"><i class="fas fa-camera fa-2x"></i></div>
                    {% endif %}
                    
                    <h3>{{ recipe.title }}</h3>
                    <div class="meta">
                        <span><i class="fas fa-star"></i> 4.8</span>
                        <span><i class="fas fa-map-marker-alt"></i> {{ recipe.region ? recipe.region.name : 'Global' }}</span>
                    </div>
                    
                    <div class="price-row">
                        <div class="servings"><span>SVGS</span> {{ recipe.baseServings }}</div>
                        <a href="{{ path('app_chef_recipe_show', {'id': recipe.id}) }}" class="btn-add">View</a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div style="text-align: center; padding: 60px 20px; background: #fff; border-radius: 20px; border: 1px dashed #ddd;">
            <i class="fas fa-hamburger fa-3x" style="color: #ddd; margin-bottom: 15px;"></i>
            <h3 style="margin: 0 0 10px 0; color: #555;">No recipes yet</h3>
            <a href="{{ path('app_chef_recipe_new') }}" class="btn-primary" style="margin-top: 10px;">Add Recipe</a>
        </div>
    {% endif %}
{% endblock %}

{% block right_panel %}
    <div class="right-panel">
        <h2 class="section-title" style="font-size: 1.2rem;">Portfolio Summary</h2>
        
        <div class="recent-list" style="margin-bottom: 30px;">
            {% for recipe in recentRecipes|slice(0, 3) %}
                <div class="recent-item">
                    {% if recipe.image %}
                        <img src="{{ asset('uploads/recipes/' ~ recipe.image) }}" alt="{{ recipe.title }}">
                    {% else %}
                        <div style="width: 55px; height: 55px; border-radius: 12px; background: #eee; display: flex; align-items: center; justify-content: center; color: #aaa;"><i class="fas fa-image"></i></div>
                    {% endif %}
                    <div class="info">
                        <h5>{{ recipe.title }}</h5>
                        <p>{{ recipe.region ? recipe.region.name : 'Global' }}</p>
                    </div>
                    <div class="price">{{ recipe.baseServings }}s</div>
                </div>
            {% else %}
                <p style="color: #888; font-size: 0.9rem;">No recipes added yet.</p>
            {% endfor %}
        </div>

        <div class="summary-card">
            <h4>Chef Performance</h4>
            <div class="stat-row">
                <span>Total Recipes</span>
                <strong>{{ recipeCount }}</strong>
            </div>
            <div class="stat-row">
                <span>Avg. Servings</span>
                <strong>4.5</strong>
            </div>
            <div class="stat-row">
                <span>Rating</span>
                <strong><i class="fas fa-star" style="color: #ffc107;"></i> 4.9</strong>
            </div>
            <div class="stat-total">
                <span>Total Impact</span>
                <span style="color: #ff5722;">{{ recipeCount * 45 }} views</span>
            </div>
            
            <button class="btn-primary" style="width: 100%; margin-top: 20px; font-size: 1rem; padding: 15px;">Share Portfolio</button>
        </div>
    </div>
{% endblock %}

