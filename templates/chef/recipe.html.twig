{% extends 'chef/layout.html.twig' %}

{% block chef_styles %}
<style>
    .action-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    
    .food-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 25px; }
    .food-card { background: #fff; border-radius: 20px; padding: 25px 20px; text-align: center; box-shadow: 0 5px 20px rgba(0,0,0,0.03); transition: all 0.3s; position: relative; border: 1px solid #f9f9f9; }
    .food-card:hover { border-color: #ff5722; box-shadow: 0 10px 30px rgba(255,87,34,0.1); transform: translateY(-5px); }
    .food-card img { width: 130px; height: 130px; border-radius: 50%; object-fit: cover; margin: 0 auto 20px; box-shadow: 0 10px 20px rgba(0,0,0,0.1); border: 4px solid #fff; }
    .food-card .no-image { width: 130px; height: 130px; border-radius: 50%; background: #f0f0f0; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center; color: #aaa; border: 4px solid #fff; }
    .food-card h3 { font-size: 1.1rem; margin: 0 0 5px 0; color: #222; font-weight: 600; }
    .food-card .meta { display: flex; justify-content: center; gap: 15px; color: #888; font-size: 0.85rem; margin-bottom: 20px; font-weight: 500; }
    
    .card-actions { display: flex; justify-content: center; gap: 10px; border-top: 1px dashed #eee; padding-top: 20px; margin-top: auto; }
    .btn-icon { width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: none; cursor: pointer; transition: all 0.3s; font-size: 0.9rem; }
    .btn-edit { background: #f8f9fa; color: #555; }
    .btn-edit:hover { background: #e9ecef; color: #111; }
    .btn-delete { background: #fff5f2; color: #ff5722; }
    .btn-delete:hover { background: #ff5722; color: #fff; }
    .btn-view { background: #ff5722; color: #fff; padding: 0 20px; border-radius: 30px; height: 38px; font-weight: 600; text-decoration: none; display: flex; align-items: center; }
    .btn-view:hover { background: #e64a19; }
</style>
{% endblock %}

{% block chef_content %}
    <div class="action-header">
        <h2 class="section-title" style="margin: 0;">My Food Menu</h2>
        <a href="{{ path('app_chef_recipe_new') }}" class="btn-primary"><i class="fas fa-plus"></i> Add New</a>
    </div>

    {% if recipes|length > 0 %}
        <div class="food-grid">
            {% for recipe in recipes %}
                <div class="food-card" style="display: flex; flex-direction: column;">
                    {% if recipe.image %}
                        <img src="{{ asset('uploads/recipes/' ~ recipe.image) }}" alt="{{ recipe.title }}">
                    {% else %}
                        <div class="no-image"><i class="fas fa-camera fa-2x"></i></div>
                    {% endif %}
                    
                    <h3>{{ recipe.title }}</h3>
                    <div class="meta">
                        <span><i class="fas fa-users"></i> {{ recipe.baseServings }} Svgs</span>
                        <span><i class="fas fa-map-marker-alt"></i> {{ recipe.region ? recipe.region.name : 'Global' }}</span>
                    </div>
                    
                    <div class="card-actions" style="align-items: center;">
                        <a href="{{ path('app_chef_recipe_edit', {'id': recipe.id}) }}" class="btn-icon btn-edit" title="Edit" style="text-decoration: none;"><i class="fas fa-pen"></i></a>
                        <a href="{{ path('app_chef_recipe_show', {'id': recipe.id}) }}" class="btn-view">View</a>
                        <form method="post" action="{{ path('app_chef_recipe_delete', {'id': recipe.id}) }}" onsubmit="return confirm('Are you sure you want to delete this recipe?');" style="margin: 0;">
                            <input type="hidden" name="_method" value="DELETE">
                            <button type="submit" class="btn-icon btn-delete" title="Delete"><i class="fas fa-trash"></i></button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div style="text-align: center; padding: 60px 20px; background: #fff; border-radius: 20px; border: 1px dashed #ddd;">
            <i class="fas fa-hamburger fa-4x" style="color: #ddd; margin-bottom: 20px;"></i>
            <h2 style="margin: 0 0 10px 0; color: #333;">No recipes found</h2>
            <p style="color: #666; margin-bottom: 30px;">You haven't added any recipes to your menu yet.</p>
            <a href="{{ path('app_chef_recipe_new') }}" class="btn-primary">Create Your First Recipe</a>
        </div>
    {% endif %}
{% endblock %}
