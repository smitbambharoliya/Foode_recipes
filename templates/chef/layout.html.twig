{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('css/chef_layout.css') }}">
    {% block chef_styles %}{% endblock %}
{% endblock %}

{% block body %}
<div class="app-layout">
    <!-- Left Sidebar -->
    <div class="sidebar">
        <div class="brand">
            <i class="fas fa-burger"></i> foodchef
        </div>
        <ul class="sidebar-menu">
            <li><a href="{{ path('app_chef_dashboard') }}" class="{% if app.request.attributes.get('_route') == 'app_chef_dashboard' %}active{% endif %}"><i class="fas fa-home"></i> Dashboard</a></li>
            <li><a href="{{ path('app_chef_recipe') }}" class="{% if app.request.attributes.get('_route') == 'app_chef_recipe' %}active{% endif %}"><i class="fas fa-list-alt"></i> Food Menu</a></li>
            <li><a href="{{ path('app_chef_recipe_new') }}" class="{% if app.request.attributes.get('_route') == 'app_chef_recipe_new' %}active{% endif %}"><i class="fas fa-plus-circle"></i> Add Recipe</a></li>
            
            <li style="margin-top: 50px;"><a href="{{ path('app_home') }}"><i class="fas fa-globe"></i> Main Site</a></li>
            <li><a href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
        </ul>
        

    </div>
    
    <!-- Main Area -->
    <div class="main-wrapper">
        <!-- Top Nav -->
        <div class="top-nav">
            <div class="search-bar">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search for recipes or categories...">
            </div>
            <div class="user-nav">
                <div class="user-profile">
                    <img src="https://ui-avatars.com/api/?name={{ app.user ? app.user.name : 'Chef' }}&background=ff5722&color=fff" alt="Profile">
                    <span>Chef {{ app.user ? app.user.name : 'User' }}</span>
                </div>
            </div>
        </div>
        
        <!-- Content Area -->
        <div class="content-area">
            <div class="main-content">
                {% for label, messages in app.flashes %}
                    <div class="flash-messages">
                        {% for message in messages %}
                            <div class="flash-alert flash-alert-{{ label }}">
                                {{ message|trans }}
                            </div>
                        {% endfor %}
                    </div>
                {% endfor %}

                {% block chef_content %}{% endblock %}
            </div>
            
            {% block right_panel %}{% endblock %}
        </div>
    </div>
</div>
{% endblock %}

