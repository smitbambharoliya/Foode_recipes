{% extends 'chef/layout.html.twig' %}

{% block page_title %}{{ recipe.title }} - Chef View{% endblock %}

{% block chef_styles %}
<link rel="stylesheet" href="{{ asset('css/chef_recipe_show.css') }}">
{% endblock %}

{% block chef_content %}
    <a href="{{ path('app_chef_recipe') }}" class="back-btn">
        <i class="fas fa-arrow-left"></i> Back to Food Menu
    </a>

    <div class="recipe-detail-card">
        <div class="recipe-meta-grid">
            <div class="recipe-image-preview">
                {% if recipe.image %}
                    <img src="{{ asset('uploads/recipes/' ~ recipe.image) }}" alt="{{ recipe.title }}">
                {% else %}
                    <div class="no-img-preview">
                        <i class="fas fa-camera fa-3x" style="margin-bottom: 15px;"></i>
                        <span>No image uploaded</span>
                    </div>
                {% endif %}
            </div>
            
            <div style="display: flex; flex-direction: column; justify-content: space-between;">
                <div>
                    <h2 style="font-size: 2.2rem; font-weight:700; margin: 0 0 20px 0; color: #111;">{{ recipe.title }}</h2>
                    
                    <div class="info-item">
                        <span class="info-label">Cuisine / Region</span>
                        <span class="info-value">{{ recipe.region ? recipe.region.name : 'Global' }}</span>
                    </div>
                    
                    <div class="info-item">
                        <span class="info-label">Base Servings</span>
                        <span class="info-value">{{ recipe.baseServings }} servings</span>
                    </div>

                    <div class="info-item">
                        <span class="info-label">Popularity</span>
                        <span class="info-value">
                            <i class="fas fa-eye" style="color:#ff5722;"></i> {{ recipe.recipeViews|length }} Views
                        </span>
                    </div>
                </div>

                <div class="action-row">
                    <a href="{{ path('app_chef_recipe_edit', {'id': recipe.id}) }}" class="btn-primary" style="padding: 10px 25px;">
                        <i class="fas fa-pen"></i> Edit Recipe
                    </a>
                    
                    <form method="post" action="{{ path('app_chef_recipe_delete', {'id': recipe.id}) }}" style="display: inline-block;" onsubmit="return confirm('Are you sure you want to delete this recipe?');">
                        <input type="hidden" name="_method" value="DELETE">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ recipe.id) }}">
                        <button type="submit" class="btn-outline" style="border-color: #ef4444; color: #ef4444; background: transparent; padding: 8px 23px;">
                            <i class="fas fa-trash"></i> Delete
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="panel-section">
            <h3 class="section-title"><i class="fas fa-carrot" style="color: #ff5722; margin-right: 5px;"></i> Ingredients</h3>
            <table class="ingredients-table">
                <thead>
                    <tr>
                        <th>Ingredient</th>
                        <th>Base Quantity</th>
                        <th>Unit</th>
                    </tr>
                </thead>
                <tbody>
                    {% for ingredient in recipe.ingredients %}
                        <tr>
                            <td style="font-weight: 500;">{{ ingredient.name }}</td>
                            <td style="color: #ff5722; font-weight: 600;">{{ ingredient.baseQuantity }}</td>
                            <td>{{ ingredient.unit }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" style="text-align: center; color: #888;">No ingredients specified.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="panel-section">
            <h3 class="section-title"><i class="fas fa-list-ol" style="color: #ff5722; margin-right: 5px;"></i> Cooking Instructions</h3>
            <div style="line-height: 1.8; color: #555; white-space: pre-line;">
                {{ recipe.instructions }}
            </div>
        </div>
    </div>
{% endblock %}

