{% extends 'chef/layout.html.twig' %}

{% block page_title %}Add New Recipe{% endblock %}

{% block chef_styles %}
<style>
    .futuristic-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
        padding: 40px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        margin: 0 auto;
    }
    .futuristic-card:hover {
        box-shadow: 0 15px 50px rgba(0, 0, 0, 0.12);
    }
    .futuristic-form-group {
        margin-bottom: 25px;
        position: relative;
    }
    .futuristic-label {
        font-weight: 700;
        color: #444;
        margin-bottom: 8px;
        display: block;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        font-size: 0.8rem;
    }
    .futuristic-input {
        background: #f8f9fa;
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 14px 20px;
        width: 100%;
        color: #333;
        font-size: 1rem;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
        box-sizing: border-box;
    }
    .futuristic-input:focus {
        border-color: #ff5722;
        background: #fff;
        box-shadow: 0 0 0 4px rgba(255, 87, 34, 0.15);
        outline: none;
        transform: translateY(-2px);
    }
    select.futuristic-input {
        appearance: none;
        background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23ff5722' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 1rem center;
        background-size: 1em;
    }
    .futuristic-row {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }
    .futuristic-col {
        flex: 1;
        min-width: 200px;
    }
    .section-header {
        font-size: 1.1rem;
        font-weight: 800;
        color: #ff5722;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        text-transform: uppercase;
        letter-spacing: 2px;
        border-bottom: 2px solid rgba(255, 87, 34, 0.1);
        padding-bottom: 10px;
    }
    .ingredients-container {
        background: rgba(248, 249, 250, 0.7);
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 15px;
        padding: 25px;
        margin-bottom: 30px;
    }
    .ingredient-item {
        display: flex;
        gap: 15px;
        align-items: center;
        background: #fff;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 15px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        transition: all 0.3s ease;
        border: 1px solid transparent;
    }
    .ingredient-item:hover {
        transform: scale(1.01);
        border-color: rgba(255, 87, 34, 0.2);
        box-shadow: 0 6px 20px rgba(255, 87, 34, 0.08);
    }
    .ingredient-item .futuristic-form-group {
        margin-bottom: 0;
    }
    .btn-delete-futuristic {
        background: #ffebee;
        color: #f44336;
        border: none;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    .btn-delete-futuristic:hover {
        background: #f44336;
        color: #fff;
        transform: rotate(90deg);
    }
    .btn-add-futuristic {
        background: transparent;
        color: #ff5722;
        border: 2px dashed #ff5722;
        border-radius: 12px;
        padding: 12px;
        width: 100%;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .btn-add-futuristic:hover {
        background: rgba(255, 87, 34, 0.05);
        transform: translateY(-2px);
    }
    .futuristic-upload {
        border: 2px dashed #ff5722;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        cursor: pointer;
        width: 100%;
        border-radius: 15px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        background: rgba(255, 87, 34, 0.02);
        box-sizing: border-box;
    }
    .futuristic-upload:hover {
        background: rgba(255, 87, 34, 0.08);
        transform: scale(1.02);
        border-color: #e64a19;
    }
    .futuristic-upload i {
        color: #ff5722;
        font-size: 3rem;
        margin-bottom: 15px;
        transition: transform 0.3s ease;
    }
    .futuristic-upload:hover i {
        transform: translateY(-5px);
    }
    .futuristic-upload span {
        font-weight: 600;
        color: #555;
    }
    .btn-submit-futuristic {
        background: linear-gradient(135deg, #ff5722, #ff9800);
        color: white;
        border: none;
        border-radius: 30px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        box-shadow: 0 4px 15px rgba(255, 87, 34, 0.4);
        transition: all 0.3s ease;
        width: 100%;
        padding: 18px;
        font-size: 1.1rem;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        margin-top: 20px;
    }
    .btn-submit-futuristic:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(255, 87, 34, 0.6);
        background: linear-gradient(135deg, #e64a19, #f57c00);
    }
    .form-error-msg {
        color: #f44336;
        font-size: 0.85rem;
        margin-top: 5px;
        font-weight: 600;
    }
</style>
{% endblock %}

{% block chef_content %}
    <div class="card futuristic-card" style="max-width: 900px;">
        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data', 'class': 'futuristic-form-wrapper'}}) }}
            
            {% if not form.vars.valid %}
                <div style="background: #ffebee; border-left: 4px solid #f44336; padding: 15px; margin-bottom: 20px; border-radius: 8px; color: #d32f2f; font-weight: bold;">
                    Please fix the errors below before saving.
                </div>
            {% endif %}

            <div class="futuristic-form-group">
                {{ form_label(form.title, 'Recipe Title', {'label_attr': {'class': 'futuristic-label'}}) }}
                {{ form_widget(form.title, {'attr': {'class': 'futuristic-input', 'placeholder': 'e.g. Sizzling Paneer Tikka'}}) }}
                <div class="form-error-msg">{{ form_errors(form.title) }}</div>
            </div>

            <div class="futuristic-form-group">
                {{ form_label(form.instructions, 'Cooking Instructions', {'label_attr': {'class': 'futuristic-label'}}) }}
                {{ form_widget(form.instructions, {'attr': {'class': 'futuristic-input', 'placeholder': 'Describe the magic steps...', 'rows': '5'}}) }}
                <div class="form-error-msg">{{ form_errors(form.instructions) }}</div>
            </div>

            <div class="futuristic-row">
                <div class="futuristic-col futuristic-form-group">
                    {{ form_label(form.baseServings, 'Servings', {'label_attr': {'class': 'futuristic-label'}}) }}
                    {{ form_widget(form.baseServings, {'attr': {'class': 'futuristic-input', 'placeholder': 'e.g. 4'}}) }}
                    <div class="form-error-msg">{{ form_errors(form.baseServings) }}</div>
                </div>
                <div class="futuristic-col futuristic-form-group">
                    {{ form_label(form.mealtype, 'Meal Type', {'label_attr': {'class': 'futuristic-label'}}) }}
                    {{ form_widget(form.mealtype, {'attr': {'class': 'futuristic-input'}}) }}
                    <div class="form-error-msg">{{ form_errors(form.mealtype) }}</div>
                </div>
                <div class="futuristic-col futuristic-form-group">
                    {{ form_label(form.isVeg, 'Dietary Preference', {'label_attr': {'class': 'futuristic-label'}}) }}
                    {{ form_widget(form.isVeg, {'attr': {'class': 'futuristic-input'}}) }}
                    <div class="form-error-msg">{{ form_errors(form.isVeg) }}</div>
                </div>
                <div class="futuristic-col futuristic-form-group">
                    {{ form_label(form.regionName, 'Cuisine/Region', {'label_attr': {'class': 'futuristic-label'}}) }}
                    {{ form_widget(form.regionName, {'attr': {'class': 'futuristic-input'}}) }}
                    <div class="form-error-msg">{{ form_errors(form.regionName) }}</div>
                    <datalist id="region-list">
                        {% for r in regions %}
                            <option value="{{ r.name }}">
                        {% endfor %}
                    </datalist>
                </div>
            </div>

            <div class="ingredients-container">
                <div class="section-header">
                    <i class="fas fa-carrot"></i> Ingredients List
                </div>
                
                {% set ingredient_prototype %}
                    <div class="ingredient-item">
                        <div class="futuristic-form-group" style="flex: 2;">
                            {{ form_widget(form.ingredients.vars.prototype.name, {'attr': {'class': 'futuristic-input', 'placeholder': 'Ingredient Name'}}) }}
                        </div>
                        <div class="futuristic-form-group" style="flex: 1;">
                            {{ form_widget(form.ingredients.vars.prototype.baseQuantity, {'attr': {'class': 'futuristic-input', 'placeholder': 'Qty'}}) }}
                        </div>
                        <div class="futuristic-form-group" style="flex: 1;">
                            {{ form_widget(form.ingredients.vars.prototype.unit, {'attr': {'class': 'futuristic-input', 'placeholder': 'Unit'}}) }}
                        </div>
                        <button type="button" class="btn-delete-futuristic remove-ingredient" title="Remove">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                {% endset %}
                
                <div class="ingredients-wrapper"
                     data-index="{{ form.ingredients|length > 0 ? form.ingredients|last.vars.name + 1 : 0 }}"
                     data-prototype="{{ ingredient_prototype|e('html_attr') }}">
                    
                    <div id="ingredient-fields-list">
                        {% for ingredient in form.ingredients %}
                            <div class="ingredient-item">
                                <div class="futuristic-form-group" style="flex: 2;">
                                    {{ form_widget(ingredient.name, {'attr': {'class': 'futuristic-input'}}) }}
                                </div>
                                <div class="futuristic-form-group" style="flex: 1;">
                                    {{ form_widget(ingredient.baseQuantity, {'attr': {'class': 'futuristic-input'}}) }}
                                </div>
                                <div class="futuristic-form-group" style="flex: 1;">
                                    {{ form_widget(ingredient.unit, {'attr': {'class': 'futuristic-input'}}) }}
                                </div>
                                <button type="button" class="btn-delete-futuristic remove-ingredient" title="Remove">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        {% endfor %}
                    </div>
                    
                    <button type="button" class="btn-add-futuristic add-another-ingredient">
                        <i class="fas fa-plus-circle"></i> Add Another Ingredient
                    </button>
                </div>
            </div>

            <div class="futuristic-form-group">
                {{ form_label(form.image, 'Delicious Recipe Image', {'label_attr': {'class': 'futuristic-label'}}) }}
                <label class="futuristic-upload">
                    <i class="fas fa-cloud-upload-alt"></i>
                    <span>Click or Drag to Upload Image</span>
                    {{ form_widget(form.image, {'attr': {'style': 'display: none;'}}) }}
                </label>
                <div class="form-error-msg">{{ form_errors(form.image) }}</div>
            </div>

            <button type="submit" class="btn-submit-futuristic">
                <i class="fas fa-rocket" style="margin-right: 8px;"></i> Launch Recipe
            </button>

        {{ form_end(form) }}
    </div>

<script>
(function() {
    const wrapper = document.querySelector('.ingredients-wrapper');
    if (!wrapper) return;
    const list = document.getElementById('ingredient-fields-list');
    const addButton = document.querySelector('.add-another-ingredient');
    
    // Add new ingredient
    addButton.addEventListener('click', function(e) {
        let prototype = wrapper.dataset.prototype;
        let index = wrapper.dataset.index;
        
        let newForm = prototype.replace(/__name__/g, index);
        wrapper.dataset.index = parseInt(index) + 1;
        
        let tempDiv = document.createElement('div');
        tempDiv.innerHTML = newForm.trim();
        let newElement = tempDiv.firstElementChild;
        
        if (newElement) {
            // Add a small entrance animation
            newElement.style.opacity = '0';
            newElement.style.transform = 'translateY(10px)';
            list.appendChild(newElement);
            
            // Trigger reflow
            void newElement.offsetWidth;
            
            newElement.style.transition = 'all 0.4s ease';
            newElement.style.opacity = '1';
            newElement.style.transform = 'translateY(0)';
        }
    });
    
    // Remove ingredient
    list.addEventListener('click', function(e) {
        let removeBtn = e.target.closest('.remove-ingredient');
        if(removeBtn) {
            let item = removeBtn.closest('.ingredient-item');
            item.style.transform = 'scale(0.9)';
            item.style.opacity = '0';
            setTimeout(() => {
                item.remove();
            }, 300);
        }
    });
    
    // Add one empty ingredient row by default if the list is empty
    if(list.children.length === 0) {
        addButton.click();
    }
})();
</script>
{% endblock %}
