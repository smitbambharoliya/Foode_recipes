{% extends 'base.html.twig' %}

{% block title %}Recipes - Foode Recipes{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --primary: #ff5722;
            --primary-hover: #e64a19;
            --primary-light: #fff5f2;
            --dark: #0f172a;
            --gray-light: #f8fafc;
            --text-main: #334155;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
            --glass-bg: rgba(255, 255, 255, 0.45);
            --glass-border: rgba(255, 255, 255, 0.25);
            --glass-blur: blur(16px);
        }

        .glass-panel {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: linear-gradient(135deg, #fef2f2 0%, #fff7ed 50%, #f0fdf4 100%);
            background-attachment: fixed;
            margin: 0;
            color: var(--text-main);
            min-height: 100vh;
        }

        /* Premium Header */
        header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--glass-border);
            box-shadow: var(--shadow-sm);
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 15px 30px;
            box-sizing: border-box;
        }

        .logo {
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--primary);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
            letter-spacing: -0.5px;
        }

        .logo i {
            transform: rotate(-10deg);
            transition: transform 0.3s ease;
        }

        .logo:hover i {
            transform: rotate(10deg) scale(1.1);
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 25px;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .nav-links a {
            color: var(--text-main);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
            font-size: 0.95rem;
        }

        .nav-links a:hover {
            color: var(--primary);
        }

        .nav-links .active {
            color: var(--primary);
            font-weight: 600;
        }

        .btn-chef-panel {
            background: var(--primary-light);
            color: var(--primary) !important;
            padding: 8px 18px;
            border-radius: 50px;
            font-weight: 600 !important;
            border: 1px solid rgba(255, 87, 34, 0.15);
            transition: all 0.3s !important;
        }

        .btn-chef-panel:hover {
            background: var(--primary);
            color: #fff !important;
            box-shadow: 0 4px 10px rgba(255, 87, 34, 0.2);
        }

        /* Banner section */
        .page-banner {
            max-width: 1200px;
            margin: 40px auto 20px;
            padding: 0 30px;
            box-sizing: border-box;
            text-align: center;
        }

        .page-banner h1 {
            font-size: 2.8rem;
            font-weight: 800;
            margin: 0 0 10px 0;
            color: var(--dark);
            letter-spacing: -1px;
        }

        .page-banner p {
            font-size: 1.1rem;
            color: var(--text-muted);
            margin: 0;
            max-width: 600px;
            margin: 0 auto;
        }

        /* Main Grid */
        .recipes-section {
            max-width: 1200px;
            margin: 20px auto 60px;
            padding: 0 30px;
            box-sizing: border-box;
        }

        .recipes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 30px;
        }

        .recipe-card {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .recipe-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-lg);
            border-color: rgba(255, 87, 34, 0.2);
        }

        .card-image-wrapper {
            position: relative;
            padding-bottom: 65%; /* 3:2 Aspect Ratio */
            overflow: hidden;
            background: #e2e8f0;
        }

        .card-image-wrapper img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .recipe-card:hover .card-image-wrapper img {
            transform: scale(1.08);
        }

        .no-image-placeholder {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #cbd5e1 0%, #94a3b8 100%);
            color: #fff;
        }

        .cuisine-badge {
            position: absolute;
            top: 15px;
            left: 15px;
            background: rgba(15, 23, 42, 0.75);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            color: #fff;
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .views-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            background: rgba(255, 255, 255, 0.9);
            color: var(--dark);
            padding: 6px 12px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 5px;
            box-shadow: var(--shadow-sm);
        }

        .card-content {
            padding: 22px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .recipe-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--dark);
            margin: 0 0 10px 0;
            line-height: 1.3;
            transition: color 0.3s;
        }

        .recipe-card:hover .recipe-title {
            color: var(--primary);
        }

        .recipe-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 20px;
            border-bottom: 1px solid #f1f5f9;
            padding-bottom: 15px;
        }

        .rating-stars {
            display: flex;
            align-items: center;
            gap: 2px;
            color: #ffb703;
        }

        .rating-text {
            font-weight: 600;
            color: var(--dark);
            margin-left: 4px;
        }

        .btn-view-recipe {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background: var(--dark);
            color: #fff;
            padding: 12px;
            border-radius: 14px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s;
            margin-top: auto;
        }

        .recipe-card:hover .btn-view-recipe {
            background: var(--primary);
            box-shadow: 0 5px 15px rgba(255, 87, 34, 0.3);
        }

        /* Flash messages styling */
        .flash-messages {
            max-width: 1200px;
            margin: 20px auto 0;
            padding: 0 30px;
            box-sizing: border-box;
        }
        .flash-alert {
            padding: 15px 20px;
            border-radius: 12px;
            margin-bottom: 15px;
            font-weight: 500;
        }
        .flash-alert-success {
            background-color: #dcfce7;
            color: #166534;
            border: 1px solid #bbf7d0;
        }
        .flash-alert-error {
            background-color: #fee2e2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

        /* Search Container & Bar */
        .search-container {
            max-width: 600px;
            margin: 30px auto 10px;
        }

        .search-form {
            display: flex;
            gap: 12px;
            background: #fff;
            padding: 8px;
            border-radius: 50px;
            box-shadow: var(--shadow-md);
            border: 1px solid var(--border);
            transition: all 0.3s ease;
        }

        .search-form:focus-within {
            border-color: var(--primary);
            box-shadow: 0 10px 25px -5px rgba(255, 87, 34, 0.15), var(--shadow-md);
            transform: translateY(-2px);
        }

        .search-input-wrapper {
            position: relative;
            flex-grow: 1;
            display: flex;
            align-items: center;
        }

        .search-icon {
            position: absolute;
            left: 18px;
            color: var(--text-muted);
            font-size: 1.1rem;
        }

        .search-input {
            width: 100%;
            border: none;
            outline: none;
            padding: 12px 12px 12px 48px;
            font-size: 1rem;
            font-family: inherit;
            color: var(--dark);
            border-radius: 50px;
        }

        .search-clear-btn {
            position: absolute;
            right: 15px;
            color: var(--text-muted);
            transition: color 0.2s;
            text-decoration: none;
        }

        .search-clear-btn:hover {
            color: var(--primary);
        }

        .btn-search {
            background: var(--primary);
            color: #fff;
            border: none;
            padding: 12px 30px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: background-color 0.2s, transform 0.2s;
        }

        .btn-search:hover {
            background: var(--primary-hover);
            transform: scale(1.02);
        }
        
        .btn-search:active {
            transform: scale(0.98);
        }

        /* Category Pills styling */
        .category-container {
            max-width: 800px;
            margin: 25px auto 10px;
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 10px;
        }

        .category-pill {
            display: inline-flex;
            align-items: center;
            background: #fff;
            color: var(--text-main);
            text-decoration: none;
            padding: 8px 18px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            border: 1px solid var(--border);
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: var(--shadow-sm);
        }

        .category-pill:hover {
            border-color: var(--primary);
            color: var(--primary);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 87, 34, 0.12);
        }

        .category-pill.active {
            background: var(--primary);
            color: #fff;
            border-color: var(--primary);
            box-shadow: 0 4px 12px rgba(255, 87, 34, 0.25);
        }

        /* Featured Recipe styling */
        .featured-section {
            margin-bottom: 50px;
        }

        .section-title {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--dark);
            margin: 0 0 25px 0;
            letter-spacing: -0.5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-title i {
            color: var(--primary);
        }

        .featured-card {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 32px;
            box-shadow: var(--shadow-md);
            overflow: hidden;
            display: grid;
            grid-template-columns: 1.3fr 1fr;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .featured-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
            border-color: rgba(255, 87, 34, 0.15);
        }

        @media (max-width: 768px) {
            .featured-card {
                grid-template-columns: 1fr;
            }
        }

        .featured-img-wrapper {
            position: relative;
            min-height: 320px;
            background: linear-gradient(135deg, #cbd5e1 0%, #94a3b8 100%);
        }

        .featured-img-wrapper img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .featured-badge {
            position: absolute;
            top: 20px;
            left: 20px;
            background: linear-gradient(45deg, #ff9f43, var(--primary));
            color: #fff;
            padding: 8px 16px;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            box-shadow: 0 4px 10px rgba(255, 87, 34, 0.3);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .featured-content {
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .featured-title {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--dark);
            margin: 0 0 15px 0;
            line-height: 1.2;
            letter-spacing: -0.8px;
        }

        .featured-desc {
            color: var(--text-muted);
            line-height: 1.6;
            margin-bottom: 25px;
            font-size: 1rem;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .featured-meta {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 30px;
            font-size: 0.9rem;
            color: var(--text-main);
            flex-wrap: wrap;
        }

        .featured-meta-item {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn-featured {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background: var(--dark);
            color: #fff;
            text-decoration: none;
            padding: 14px 28px;
            border-radius: 16px;
            font-weight: 600;
            transition: all 0.3s;
            align-self: flex-start;
        }

        .btn-featured:hover {
            background: var(--primary);
            box-shadow: 0 5px 15px rgba(255, 87, 34, 0.3);
        }

        /* Grid layout for Main content + Sidebar */
        .home-layout-grid {
            display: grid;
            grid-template-columns: 2.2fr 1fr;
            gap: 40px;
            margin-bottom: 50px;
        }

        @media (max-width: 992px) {
            .home-layout-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Sidebar recommendations */
        .sidebar-section {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border);
            border-radius: 28px;
            padding: 30px;
            box-shadow: var(--shadow-sm);
            height: fit-content;
        }

        .sidebar-title {
            font-size: 1.3rem;
            font-weight: 750;
            color: var(--dark);
            margin: 0 0 20px 0;
            border-bottom: 2px solid var(--border);
            padding-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .sidebar-title i {
            color: var(--primary);
        }

        .sidebar-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .sidebar-card {
            display: flex;
            gap: 15px;
            text-decoration: none;
            color: inherit;
            padding: 10px;
            border-radius: 16px;
            transition: all 0.2s;
        }

        .sidebar-card:hover {
            background: rgba(255, 255, 255, 0.6);
            transform: scale(1.02);
        }

        .sidebar-img {
            width: 70px;
            height: 70px;
            border-radius: 12px;
            object-fit: cover;
            background: #cbd5e1;
            flex-shrink: 0;
        }

        .sidebar-no-img {
            width: 70px;
            height: 70px;
            border-radius: 12px;
            background: linear-gradient(135deg, #cbd5e1 0%, #94a3b8 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .sidebar-info {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .sidebar-recipe-title {
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--dark);
            margin: 0 0 4px 0;
            line-height: 1.3;
        }

        .sidebar-recipe-chef {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-bottom: 4px;
        }

        .sidebar-recipe-views {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* Bottom Section Explore */
        .explore-section {
            margin-top: 40px;
        }

        .filter-result-header {
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 1px solid var(--border);
        }
    </style>
{% endblock %}

{% block body %}
    <header>
        <div class="nav-container">
            <a href="{{ path('app_home') }}" class="logo">
                <i class="fas fa-burger"></i> foodchef
            </a>
            <ul class="nav-links">
                <li><a href="{{ path('app_home') }}" class="active">Home</a></li>
                {% if app.user %}
                    {% if is_granted('ROLE_CHEF') %}
                        <li><a href="{{ path('app_chef_dashboard') }}" class="btn-chef-panel"><i class="fas fa-columns"></i> Chef Panel</a></li>
                    {% endif %}
                    <li><a href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt"></i> Logout ({{ app.user.name }})</a></li>
                {% else %}
                    <li><a href="{{ path('app_login') }}"><i class="fas fa-sign-in-alt"></i> Login</a></li>
                    <li><a href="{{ path('app_register') }}"><i class="fas fa-user-plus"></i> Register</a></li>
                {% endif %}
            </ul>
        </div>
    </header>

    {% for label, messages in app.flashes %}
        <div class="flash-messages">
            {% for message in messages %}
                <div class="flash-alert flash-alert-{{ label }}">
                    {{ message|trans }}
                </div>
            {% endfor %}
        </div>
    {% endfor %}

    <div class="page-banner">
        <h1>Discover Culinary Magic</h1>
        <p>Explore chef-crafted recipes, adjust portions in real-time, and read feedback from food enthusiasts around the world.</p>
        
        <div class="search-container">
            <form action="{{ path('app_home') }}" method="GET" class="search-form">
                <div class="search-input-wrapper">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" name="search" class="search-input" placeholder="Search recipes, ingredients or cuisines..." value="{{ searchTerm|default('') }}">
                    {% if selectedRegionId %}
                        <input type="hidden" name="region" value="{{ selectedRegionId }}">
                    {% endif %}
                    {% if searchTerm or selectedRegionId %}
                        <a href="{{ path('app_home') }}" class="search-clear-btn" title="Clear search">
                            <i class="fas fa-times"></i>
                        </a>
                    {% endif %}
                </div>
                <button type="submit" class="btn-search">Search</button>
            </form>
        </div>

        {# Category Pills #}
        <div class="category-container">
            <a href="{{ path('app_home', searchTerm ? {'search': searchTerm} : {}) }}" class="category-pill {% if not selectedRegionId %}active{% endif %}">
                All Cuisines
            </a>
            {% for r in regions %}
                <a href="{{ path('app_home', (searchTerm ? {'search': searchTerm} : {})|merge({'region': r.id})) }}" class="category-pill {% if selectedRegionId == r.id %}active{% endif %}">
                    {{ r.name }}
                </a>
            {% endfor %}
        </div>
    </div>

    <main class="recipes-section">
        {% if recipes is not empty %}
            {% if searchTerm or selectedRegionId %}
                {# Filtered/Searched Results View #}
                <div class="filter-result-header">
                    <h2 class="section-title">
                        <i class="fas fa-filter"></i>
                        {% if searchTerm and selectedRegionId %}
                            Results for "{{ searchTerm }}" in Cuisine: 
                            {% for r in regions %}{% if r.id == selectedRegionId %}{{ r.name }}{% endif %}{% endfor %}
                        {% elseif searchTerm %}
                            Results for "{{ searchTerm }}"
                        {% elseif selectedRegionId %}
                            Cuisine: {% for r in regions %}{% if r.id == selectedRegionId %}{{ r.name }}{% endif %}{% endfor %}
                        {% endif %}
                        <span style="font-size: 1.1rem; color: var(--text-muted); font-weight: 500; margin-left: 10px;">({{ recipes|length }} recipes found)</span>
                    </h2>
                </div>

                <div class="recipes-grid">
                    {% for item in recipes %}
                        {% set recipe = item.recipe %}
                        {% set viewCount = item.viewCount %}
                        
                        {# Calculate average rating #}
                        {% set totalRating = 0 %}
                        {% set reviewsLength = recipe.reviews|length %}
                        {% if reviewsLength > 0 %}
                            {% for r in recipe.reviews %}
                                {% set totalRating = totalRating + r.rating %}
                            {% endfor %}
                            {% set avgRating = (totalRating / reviewsLength) %}
                        {% else %}
                            {% set avgRating = 0 %}
                        {% endif %}

                        <div class="recipe-card">
                            <div class="card-image-wrapper">
                                {% if recipe.image %}
                                    <img src="{{ asset('uploads/recipes/' ~ recipe.image) }}" alt="{{ recipe.title }}" loading="lazy">
                                {% else %}
                                    <div class="no-image-placeholder">
                                        <i class="fas fa-utensils fa-2x" style="margin-bottom: 8px;"></i>
                                        <span style="font-size: 0.8rem; font-weight: 500;">No photo available</span>
                                    </div>
                                {% endif %}
                                <div class="cuisine-badge">
                                    {{ recipe.region ? recipe.region.name : 'Global' }}
                                </div>
                                <div class="views-badge">
                                    <i class="fas fa-eye" style="color: var(--primary);"></i>
                                    {{ viewCount }}
                                </div>
                            </div>

                            <div class="card-content">
                                <h2 class="recipe-title">{{ recipe.title }}</h2>
                                <div class="recipe-meta">
                                    <div>
                                        <i class="fas fa-user-circle" style="margin-right: 5px;"></i>
                                        <span>Chef {{ recipe.chef.name }}</span>
                                    </div>
                                    <div class="rating-stars">
                                        {% if reviewsLength > 0 %}
                                            <i class="fas fa-star"></i>
                                            <span class="rating-text">{{ avgRating|number_format(1) }}</span>
                                            <span style="color: var(--text-muted); font-size: 0.75rem; margin-left: 2px;">({{ reviewsLength }})</span>
                                        {% else %}
                                            <i class="far fa-star"></i>
                                            <span style="color: var(--text-muted); font-size: 0.75rem;">No reviews</span>
                                        {% endif %}
                                    </div>
                                </div>
                                <a href="{{ path('app_home_show', {'id': recipe.id}) }}" class="btn-view-recipe">
                                    <span>View Details</span>
                                    <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                {# Premium Structured Homepage #}
                
                {# Continue Reading (User History) #}
                {% if app.user and continueReading is not empty %}
                    <section class="explore-section" style="margin-bottom: 50px;">
                        <h2 class="section-title"><i class="fas fa-history"></i> Continue Cooking</h2>
                        <div class="recipes-grid">
                            {% for item in continueReading %}
                                {% set recipe = item[0].recipe %}
                                <div class="recipe-card">
                                    <div class="card-image-wrapper">
                                        {% if recipe.image %}
                                            <img src="{{ asset('uploads/recipes/' ~ recipe.image) }}" alt="{{ recipe.title }}" loading="lazy">
                                        {% else %}
                                            <div class="no-image-placeholder">
                                                <i class="fas fa-utensils fa-2x" style="margin-bottom: 8px;"></i>
                                                <span style="font-size: 0.8rem; font-weight: 500;">No photo available</span>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="card-content">
                                        <h2 class="recipe-title">{{ recipe.title }}</h2>
                                        <span style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 15px; display: block; padding-bottom: 15px; border-bottom: 1px solid #f1f5f9;">
                                            <i class="fas fa-clock"></i> Last viewed: {{ item.lastViewed|date('M d, h:i A') }}
                                        </span>
                                        <a href="{{ path('app_home_show', {'id': recipe.id}) }}" class="btn-view-recipe">
                                            <span>Continue Cooking</span>
                                            <i class="fas fa-arrow-right"></i>
                                        </a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </section>
                {% endif %}

                {# 1. Featured Recipe Banner (First Recipe) #}
                {% set featuredItem = recipes[0] %}
                {% set featuredRecipe = featuredItem.recipe %}
                {% set featuredViews = featuredItem.viewCount %}
                
                {% set fTotalRating = 0 %}
                {% set fReviewsLen = featuredRecipe.reviews|length %}
                {% if fReviewsLen > 0 %}
                    {% for r in featuredRecipe.reviews %}
                        {% set fTotalRating = fTotalRating + r.rating %}
                    {% endfor %}
                    {% set fAvgRating = (fTotalRating / fReviewsLen) %}
                {% else %}
                    {% set fAvgRating = 0 %}
                {% endif %}

                <section class="featured-section">
                    <h2 class="section-title"><i class="fas fa-award"></i> Featured Recipe</h2>
                    <div class="featured-card">
                        <div class="featured-img-wrapper">
                            {% if featuredRecipe.image %}
                                <img src="{{ asset('uploads/recipes/' ~ featuredRecipe.image) }}" alt="{{ featuredRecipe.title }}">
                            {% else %}
                                <div class="no-image-placeholder" style="position: absolute; height:100%; width:100%;">
                                    <i class="fas fa-utensils fa-4x" style="margin-bottom: 12px;"></i>
                                    <span>Featured Dish</span>
                                </div>
                            {% endif %}
                            <div class="featured-badge">
                                <i class="fas fa-crown"></i> Chef's Choice
                            </div>
                        </div>
                        <div class="featured-content">
                            <h3 class="featured-title">{{ featuredRecipe.title }}</h3>
                            <p class="featured-desc">{{ featuredRecipe.instructions|slice(0, 180) }}...</p>
                            
                            <div class="featured-meta">
                                <div class="featured-meta-item">
                                    <i class="fas fa-map-marker-alt" style="color: var(--primary);"></i>
                                    <strong>{{ featuredRecipe.region ? featuredRecipe.region.name : 'Global' }}</strong>
                                </div>
                                <div class="featured-meta-item">
                                    <i class="fas fa-user-circle" style="color: var(--text-muted);"></i>
                                    <span>Published by <strong>Chef {{ featuredRecipe.chef.name }}</strong></span>
                                </div>
                                <div class="featured-meta-item">
                                    <i class="fas fa-star" style="color: #ffb703;"></i>
                                    <span>{{ fAvgRating|number_format(1) }} ({{ fReviewsLen }} reviews)</span>
                                </div>
                                <div class="featured-meta-item">
                                    <i class="fas fa-eye" style="color: var(--primary);"></i>
                                    <span>{{ featuredViews }} views</span>
                                </div>
                            </div>
                            
                            <a href="{{ path('app_home_show', {'id': featuredRecipe.id}) }}" class="btn-featured">
                                <span>Get Cookin'</span>
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </div>
                    </div>
                </section>

                {# 2. Main content and Sidebar Split Grid #}
                <div class="home-layout-grid">
                    {# Left Column: What's Trending #}
                    <div>
                        <h2 class="section-title"><i class="fas fa-fire"></i> What's Trending</h2>
                        <div class="recipes-grid">
                            {% for trending in trendingRecipes %}
                                {% set recipe = trending.recipe %}
                                {% set totalRating = 0 %}
                                {% set reviewsLength = recipe.reviews|length %}
                                {% if reviewsLength > 0 %}
                                    {% for r in recipe.reviews %}
                                        {% set totalRating = totalRating + r.rating %}
                                    {% endfor %}
                                    {% set avgRating = (totalRating / reviewsLength) %}
                                {% else %}
                                    {% set avgRating = 0 %}
                                {% endif %}

                                <div class="recipe-card">
                                    <div class="card-image-wrapper">
                                        {% if recipe.image %}
                                            <img src="{{ asset('uploads/recipes/' ~ recipe.image) }}" alt="{{ recipe.title }}" loading="lazy">
                                        {% else %}
                                            <div class="no-image-placeholder">
                                                <i class="fas fa-utensils fa-2x" style="margin-bottom: 8px;"></i>
                                                <span style="font-size: 0.8rem; font-weight: 500;">No photo available</span>
                                            </div>
                                        {% endif %}
                                        <div class="cuisine-badge">
                                            {{ recipe.region ? recipe.region.name : 'Global' }}
                                        </div>
                                    </div>

                                    <div class="card-content">
                                        <h2 class="recipe-title">{{ recipe.title }}</h2>
                                        <div class="recipe-meta">
                                            <div>
                                                <i class="fas fa-user-circle" style="margin-right: 5px;"></i>
                                                <span>Chef {{ recipe.chef.name }}</span>
                                            </div>
                                            <div class="rating-stars">
                                                {% if reviewsLength > 0 %}
                                                    <i class="fas fa-star"></i>
                                                    <span class="rating-text">{{ avgRating|number_format(1) }}</span>
                                                    <span style="color: var(--text-muted); font-size: 0.75rem; margin-left: 2px;">({{ reviewsLength }})</span>
                                                {% else %}
                                                    <i class="far fa-star"></i>
                                                    <span style="color: var(--text-muted); font-size: 0.75rem;">No reviews</span>
                                                {% endif %}
                                            </div>
                                        </div>
                                        <a href="{{ path('app_home_show', {'id': recipe.id}) }}" class="btn-view-recipe">
                                            <span>View Details</span>
                                            <i class="fas fa-arrow-right"></i>
                                        </a>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                    {# Right Column: Sidebar recommendations #}
                    <aside class="sidebar-section">
                        <h3 class="sidebar-title"><i class="fas fa-thumbs-up"></i> Quick Suggestions</h3>
                        <div class="sidebar-list">
                            {% for recipe in recommendedRecipes %}
                                
                                <a href="{{ path('app_home_show', {'id': recipe.id}) }}" class="sidebar-card">
                                    {% if recipe.image %}
                                        <img src="{{ asset('uploads/recipes/' ~ recipe.image) }}" alt="{{ recipe.title }}" class="sidebar-img">
                                    {% else %}
                                        <div class="sidebar-no-img">
                                            <i class="fas fa-utensils"></i>
                                        </div>
                                    {% endif %}
                                    <div class="sidebar-info">
                                        <h4 class="sidebar-recipe-title">{{ recipe.title }}</h4>
                                        <span class="sidebar-recipe-chef">By Chef {{ recipe.chef.name }}</span>
                                    </div>
                                </a>
                            {% else %}
                                <p style="color: var(--text-muted); font-size: 0.9rem; text-align: center; margin: 20px 0;">More recommendations coming soon!</p>
                            {% endfor %}
                        </div>
                    </aside>
                </div>

                {# 3. Middle Grid: Newly Added #}
                <section class="explore-section" style="margin-top: 50px; margin-bottom: 50px;">
                    <h2 class="section-title"><i class="fas fa-leaf"></i> Freshly Added Recipes</h2>
                    <div class="recipes-grid">
                        {% for recipe in newlyAdded %}
                            {% set totalRating = 0 %}
                            {% set reviewsLength = recipe.reviews|length %}
                            {% if reviewsLength > 0 %}
                                {% for r in recipe.reviews %}
                                    {% set totalRating = totalRating + r.rating %}
                                {% endfor %}
                                {% set avgRating = (totalRating / reviewsLength) %}
                            {% else %}
                                {% set avgRating = 0 %}
                            {% endif %}

                            <div class="recipe-card">
                                <div class="card-image-wrapper">
                                    {% if recipe.image %}
                                        <img src="{{ asset('uploads/recipes/' ~ recipe.image) }}" alt="{{ recipe.title }}" loading="lazy">
                                    {% else %}
                                        <div class="no-image-placeholder">
                                            <i class="fas fa-utensils fa-2x" style="margin-bottom: 8px;"></i>
                                            <span style="font-size: 0.8rem; font-weight: 500;">No photo available</span>
                                        </div>
                                    {% endif %}
                                    <div class="cuisine-badge" style="background: var(--dark); color: #fff;">
                                        {% if recipe.createdAt %}
                                            {% set difference = date().diff(date(recipe.createdAt)) %}
                                            {% if difference.days == 0 %}
                                                Added Today
                                            {% elseif difference.days == 1 %}
                                                Added Yesterday
                                            {% else %}
                                                {{ difference.days }} Days Ago
                                            {% endif %}
                                        {% else %}
                                            Recent
                                        {% endif %}
                                    </div>
                                </div>

                                <div class="card-content">
                                    <h2 class="recipe-title">{{ recipe.title }}</h2>
                                    <div class="recipe-meta">
                                        <div>
                                            <i class="fas fa-user-circle" style="margin-right: 5px;"></i>
                                            <span>Chef {{ recipe.chef.name }}</span>
                                        </div>
                                        <div class="rating-stars">
                                            {% if reviewsLength > 0 %}
                                                <i class="fas fa-star"></i>
                                                <span class="rating-text">{{ avgRating|number_format(1) }}</span>
                                                <span style="color: var(--text-muted); font-size: 0.75rem; margin-left: 2px;">({{ reviewsLength }})</span>
                                            {% else %}
                                                <i class="far fa-star"></i>
                                                <span style="color: var(--text-muted); font-size: 0.75rem;">No reviews</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <a href="{{ path('app_home_show', {'id': recipe.id}) }}" class="btn-view-recipe">
                                        <span>View Details</span>
                                        <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </section>

                {# 4. Bottom Grid: Explore All Cuisines #}
                <section class="explore-section">
                    <h2 class="section-title"><i class="fas fa-compass"></i> Explore All Recipes</h2>
                    <div class="recipes-grid">
                        {% for item in recipes %}
                            {% set recipe = item.recipe %}
                            {% set viewCount = item.viewCount %}
                            
                            {% set totalRating = 0 %}
                            {% set reviewsLength = recipe.reviews|length %}
                            {% if reviewsLength > 0 %}
                                {% for r in recipe.reviews %}
                                    {% set totalRating = totalRating + r.rating %}
                                {% endfor %}
                                {% set avgRating = (totalRating / reviewsLength) %}
                            {% else %}
                                {% set avgRating = 0 %}
                            {% endif %}

                            <div class="recipe-card">
                                <div class="card-image-wrapper">
                                    {% if recipe.image %}
                                        <img src="{{ asset('uploads/recipes/' ~ recipe.image) }}" alt="{{ recipe.title }}" loading="lazy">
                                    {% else %}
                                        <div class="no-image-placeholder">
                                            <i class="fas fa-utensils fa-2x" style="margin-bottom: 8px;"></i>
                                            <span style="font-size: 0.8rem; font-weight: 500;">No photo available</span>
                                        </div>
                                    {% endif %}
                                    <div class="cuisine-badge">
                                        {{ recipe.region ? recipe.region.name : 'Global' }}
                                    </div>
                                    <div class="views-badge">
                                        <i class="fas fa-eye" style="color: var(--primary);"></i>
                                        {{ viewCount }}
                                    </div>
                                </div>

                                <div class="card-content">
                                    <h2 class="recipe-title">{{ recipe.title }}</h2>
                                    <div class="recipe-meta">
                                        <div>
                                            <i class="fas fa-user-circle" style="margin-right: 5px;"></i>
                                            <span>Chef {{ recipe.chef.name }}</span>
                                        </div>
                                        <div class="rating-stars">
                                            {% if reviewsLength > 0 %}
                                                <i class="fas fa-star"></i>
                                                <span class="rating-text">{{ avgRating|number_format(1) }}</span>
                                                <span style="color: var(--text-muted); font-size: 0.75rem; margin-left: 2px;">({{ reviewsLength }})</span>
                                            {% else %}
                                                <i class="far fa-star"></i>
                                                <span style="color: var(--text-muted); font-size: 0.75rem;">No reviews</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <a href="{{ path('app_home_show', {'id': recipe.id}) }}" class="btn-view-recipe">
                                        <span>View Details</span>
                                        <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}
        {% else %}
            {# Empty State #}
            <div style="text-align: center; padding: 80px 20px; background: var(--glass-bg); border-radius: 32px; border: 1px dashed var(--border); box-shadow: var(--shadow-sm);">
                {% if searchTerm or selectedRegionId %}
                    <i class="fas fa-search-minus fa-4x" style="color: var(--text-muted); margin-bottom: 25px;"></i>
                    <h3 style="margin: 0 0 10px 0; font-size: 1.5rem;">No Recipes Found</h3>
                    <p style="color: var(--text-muted); margin: 0; margin-bottom: 20px;">We couldn't find any recipes matching your search criteria.</p>
                    <a href="{{ path('app_home') }}" style="display: inline-block; background: var(--dark); color: #fff; text-decoration: none; padding: 12px 28px; border-radius: 50px; font-weight: 600; transition: background-color 0.2s;">Clear Filters</a>
                {% else %}
                    <i class="fas fa-utensils fa-4x" style="color: var(--text-muted); margin-bottom: 25px;"></i>
                    <h3 style="margin: 0 0 10px 0; font-size: 1.5rem;">No Recipes Available</h3>
                    <p style="color: var(--text-muted); margin: 0;">Be the first chef to publish a recipe!</p>
                {% endif %}
            </div>
        {% endif %}
    </main>
{% endblock %}
