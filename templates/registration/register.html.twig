{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-form-section" style="padding-top: 30px; padding-bottom: 30px; overflow-y: auto;">
        <div class="brand" style="margin-bottom: 20px;">
            <i class="fas fa-bowl-food"></i> Food Recipe
        </div>
        
        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
            
            <div class="form-row">
                <div class="form-group">
                    {{ form_widget(registrationForm.name, {'attr': {'class': 'pill-input', 'placeholder': 'Full Name'}}) }}
                </div>
                <div class="form-group">
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'pill-input', 'placeholder': 'Email Address'}}) }}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'pill-input', 'placeholder': 'Password'}}) }}
                </div>
                <div class="form-group">
                    {{ form_widget(registrationForm.phone, {'attr': {'class': 'pill-input', 'placeholder': 'Phone Number'}}) }}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_widget(registrationForm.gender, {'attr': {'class': 'pill-input'}}) }}
                </div>
                <div class="form-group">
                    {{ form_widget(registrationForm.age, {'attr': {'class': 'pill-input', 'placeholder': 'Age'}}) }}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_widget(registrationForm.city, {'attr': {'class': 'pill-input', 'placeholder': 'City'}}) }}
                </div>
                <div class="form-group">
                    {{ form_widget(registrationForm.state, {'attr': {'class': 'pill-input', 'placeholder': 'State'}}) }}
                </div>
            </div>

            <div class="checkbox-group" style="margin-top: 15px; margin-bottom: 20px; display: flex; align-items: center; justify-content: center;">
                {{ form_widget(registrationForm.agreeTerms) }}
                {{ form_label(registrationForm.agreeTerms, 'I agree to the terms and conditions') }}
            </div>

            <button type="submit" class="pill-btn" style="width: 100%; font-size: 1.1rem; padding: 18px;">REGISTER</button>
        {{ form_end(registrationForm) }}

        <div class="auth-links" style="margin-top: 25px; text-align: center;">
            <p style="margin-bottom: 10px;">Already have an account? <a href="{{ path('app_login') }}">Login here</a></p>
            <p><a href="{{ path('app_home') }}">Back to Home</a></p>
        </div>
    </div>
    <div class="auth-image-section">
    </div>
</div>
{% endblock %}
