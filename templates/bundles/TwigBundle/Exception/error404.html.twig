{% extends 'base.html.twig' %}

{% block title %}404 - Page Not Found | FoodE{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .error-page-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #09090f;
            color: #f4f4f5;
            font-family: 'Inter', sans-serif;
            text-align: center;
            padding: 20px;
            position: relative;
            overflow: hidden;
        }
        .error-page-container::before {
            content: '';
            position: absolute;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(255,107,53,0.1), transparent);
            border-radius: 50%;
            filter: blur(60px);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 1;
        }
        .error-content {
            position: relative;
            z-index: 2;
        }
        .error-code {
            font-size: 8rem;
            font-weight: 900;
            font-family: 'Playfair Display', serif;
            background: linear-gradient(135deg, #ff6b35 0%, #ffd700 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
            line-height: 1;
            text-shadow: 0 10px 30px rgba(255, 107, 53, 0.2);
        }
        .error-title {
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 20px;
            font-family: 'Playfair Display', serif;
        }
        .error-message {
            font-size: 1.1rem;
            color: #a1a1aa;
            margin-bottom: 40px;
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
            line-height: 1.6;
        }
        .btn-home {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: linear-gradient(135deg, #ff6b35 0%, #ff8f50 100%);
            color: white;
            text-decoration: none;
            padding: 14px 32px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s ease;
            box-shadow: 0 8px 25px rgba(255, 107, 53, 0.3);
            border: none;
        }
        .btn-home:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(255, 107, 53, 0.5);
        }
    </style>
{% endblock %}

{% block body %}
    <div class="error-page-container">
        <div class="error-content">
            <div class="error-code">404</div>
            <h1 class="error-title">Oops! Recipe Not Found</h1>
            <p class="error-message">The page you are looking for might have been removed, had its name changed, or is temporarily unavailable. Let's get you back to cooking.</p>
            <a href="{{ path('app_home') }}" class="btn-home">
                <i class="fas fa-home"></i> Back to Home
            </a>
        </div>
    </div>
{% endblock %}
