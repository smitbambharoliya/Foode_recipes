{% extends 'base.html.twig' %}

{% block title %}404 - Page Not Found | FoodE{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('css/bundles_TwigBundle_Exception_error404.css') }}">
{% endblock %}

{% block body %}
    <div class="error-page-container">
        <div class="error-content">
            <div class="error-code">404</div>
            <h1 class="error-title">Oops! Recipe Not Found</h1>
            <p class="error-message">The page you are looking for might have been removed, had its name changed, or is temporarily unavailable. Let's get you back to cooking.</p>
            <a href="{{ path('app_home') }}" class="btn-home">
                <i class="fas fa-home"></i> Back to Home
            </a>
        </div>
    </div>
{% endblock %}

