{% extends 'base.html.twig' %}

{% block title %}403 - Access Denied | FoodE{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('css/bundles_TwigBundle_Exception_error403.css') }}">
{% endblock %}

{% block body %}
    <div class="error-page-container">
        <div class="error-content">
            <div class="error-code">403</div>
            <h1 class="error-title">Access Denied</h1>
            <p class="error-message">Sorry, you don't have permission to access this kitchen area. Only authorized chefs are allowed here.</p>
            <a href="{{ path('app_home') }}" class="btn-home">
                <i class="fas fa-home"></i> Back to Home
            </a>
        </div>
    </div>
{% endblock %}

