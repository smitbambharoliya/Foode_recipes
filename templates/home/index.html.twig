{% extends 'base.html.twig' %}

{% block title %}Food Recipe - Discover Culinary Magic{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/landing.css') }}">
{% endblock %}

{% block body %}
    <div class="hero">
        <div class="overlay"></div>
        <nav>
            <div class="logo">Food Recipe</div>
            <ul class="nav-links">
                <li><a href="{{ path('app_home') }}">Home</a></li>
                <li><a href="#">Discover</a></li>
                {% if app.user %}
                    <li><a href="{{ path('app_logout') }}">Logout</a></li>
                {% else %}
                    <li><a href="{{ path('app_login') }}">Login</a></li>
                    <li><a href="{{ path('app_register') }}">Register</a></li>
                {% endif %}
            </ul>
        </nav>
        
        <div class="hero-content">
            <h1>Culinary Magic, Redefined.</h1>
            <p>Experience thousands of premium recipes. Adjust portions dynamically and watch the ingredients scale instantly. Your ultimate cooking companion is here.</p>
            <a href="#calculator" class="cta-btn">Start Exploring</a>
        </div>
    </div>

    <section id="calculator" class="calculator-section">
        <div class="floating-circle circle-1"></div>
        <div class="floating-circle circle-2"></div>
        
        <div class="glass-card">
            <h2>Smart Scaling Engine</h2>
            <p>Featured: Paneer Tikka Masala</p>
            
            <div class="input-group">
                <label for="people-count">How many servings do you need?</label>
                <input type="number" id="people-count" value="2" min="1" max="100">
            </div>

            <div class="ingredients-list">
                <h3>Calculated Ingredients</h3>
                <ul id="ingredients">
                    <!-- Ingredients will be injected by JS -->
                </ul>
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/landing.js') }}"></script>
{% endblock %}
